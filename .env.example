# ===== Caulong production env =====
# Copy file nay thanh .env (cung thu muc docker-compose.prod.yml) roi dien gia tri that.
# docker compose tu doc .env nay de noi suy cac bien ${...}.

# Mat khau Postgres (dung cho CA container postgres LAN chuoi DATABASE_URL cua backend).
POSTGRES_PASSWORD=doi-thanh-mat-khau-manh

# Khoa ky JWT — BAT BUOC doi sang chuoi ngau nhien dai (vd: openssl rand -hex 32).
JWT_SECRET_KEY=thay-bang-chuoi-ngau-nhien-32-ky-tu-tro-len

# Origin cua frontend, dung cho CORS o backend. Khop domain Cloudflare.
BACKEND_CORS_ORIGINS=https://caulong.huyhieu.online

# URL API cho frontend — NHUNG VAO BUNDLE LUC BUILD, bat buoc co duoi "/api".
NEXT_PUBLIC_API_BASE_URL=https://api-caulong.huyhieu.online/api

# OpenAI dung cho tinh nang tro ly AI.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
